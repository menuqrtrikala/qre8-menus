  // ============================================================
  //  ΛΟΓΙΚΗ
  // ============================================================
  (function () {
    "use strict";

    const store = {
      get(k) { try { return localStorage.getItem(k); } catch (e) { return null; } },
      set(k, v) { try { localStorage.setItem(k, v); } catch (e) {} }
    };

    const I18N = {
      gr: { enter: "Δες το μενού", poweredBy: "Powered by Φίλιπς © 2023" },
      en: { enter: "View Menu", poweredBy: "Powered by Φίλιπς © 2023" }
    };

    let lang = store.get("filips-lang") || "gr";
    let activeCat = null;
    let suppressSpy = false;   // αγνόησε το scroll-spy κατά τη διάρκεια προγραμματισμένου scroll

    const $ = (sel) => document.querySelector(sel);
    const $$ = (sel) => Array.from(document.querySelectorAll(sel));
    const esc = (s) => String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));

    // δίγλωσσο lookup: EN → πεδίο "...En" με fallback, GR → πρωτεύον πεδίο με fallback
    const L = (obj, key) => {
      if (!obj) return "";
      const en = obj[key + "En"], base = obj[key];
      return lang === "en" ? (en != null ? en : (base || "")) : (base != null ? base : (en || ""));
    };
    const catTitle = (cat) => (lang === "gr" ? (cat.titleGr || cat.title) : (cat.title || cat.titleGr));
    const catSub = (cat) => cat.subtitle || "";

    function fmtPrice(price) {
      if (!price || price === "—") return esc(price || "");
      return esc(price).split("/").map((p) => p.trim()).map((p) => `${p}<span class="eur">€</span>`).join(" / ");
    }

    function groupBy(arr, keyFn) {
      return arr.reduce((acc, x) => { const k = keyFn(x); (acc[k] = acc[k] || []).push(x); return acc; }, {});
    }

    function drinkHTML(it, idx, cat) {
      const enName = cat && cat.forceEnNames;
      const displayName = enName
        ? (it.labelEn || it.nameEn || it.label || it.name || "")
        : (L(it, "label") || L(it, "name") || "");
      const delay = ((idx || 0) % 7) * 0.3;
      const colored = it.hex ? " is-color" : "";
      const cstyle = it.hex ? ` style="--c:${it.hex};--d:${delay}s"` : "";
      const nickTxt = it.nicknameEn || it.nickname || "";   // πάντα Αγγλικά, σταθερά
      const nick = nickTxt ? `<span class="dr-nick">“${esc(nickTxt)}”</span>` : "";
      const dsTxt = L(it, "desc");
      const desc = dsTxt ? `<div class="dr-desc">${esc(dsTxt)}</div>` : "";
      return `
      <div class="drink">
        <div class="dr-head">
          <span class="dr-name${colored}"${cstyle}>${esc(displayName)}</span>${nick}
          <span class="dr-price">${fmtPrice(it.price)}</span>
        </div>
        ${desc}
      </div>`;
    }

    function rowHTML(it) {
      const dsTxt = L(it, "desc");
      const desc = dsTxt ? `<div class="r-ds">${esc(dsTxt)}</div>` : "";
      return `
      <div class="row">
        <div class="r-top">
          <span class="r-nm">${esc(L(it, "name"))}</span>
          <span class="r-lead"></span>
          <span class="r-pr">${fmtPrice(it.price)}</span>
        </div>
        ${desc}
      </div>`;
    }

    function sectionHTML(cat, idx) {
      const sig = cat.style === "signature";
      const render = sig ? drinkHTML : rowHTML;
      const hasGroups = cat.items.some((it) => it.group);
      let body;
      if (hasGroups) {
        const groups = groupBy(cat.items, (it) => L(it, "group") || "");
        body = Object.keys(groups).map((g) => {
          const head = g ? `<h3 class="subgroup-title">${esc(g)}</h3>` : "";
          return head + groups[g].map((it, i) => render(it, i, cat)).join("");
        }).join("");
      } else {
        body = cat.items.map((it, i) => render(it, i, cat)).join("");
      }
      const sub = catSub(cat) ? `<div class="sub">${esc(catSub(cat))}</div>` : "";
      const num = String(idx).padStart(2, "0");
      return `
      <section class="menu-section" id="sec-${esc(cat.id)}" data-cat="${esc(cat.id)}">
        <div class="sec-head">
          <div class="sec-kicker"><span class="tri"></span> Nο ${num}</div>
          <h2>${esc(catTitle(cat))}</h2>
          ${sub}
        </div>
        ${body}
      </section>`;
    }

    function renderMenu() {
      $("#catbar").innerHTML = MENU.categories.map((cat) =>
        `<button class="chip" type="button" data-cat="${esc(cat.id)}">${esc(catTitle(cat))}</button>`
      ).join("");
      $("#menu-body").innerHTML = MENU.categories.map((cat, i) => sectionHTML(cat, i + 1)).join("");
    }

    function headOffset() {
      const h = $("#menu-header");
      return h ? h.offsetHeight : 118;
    }

    function setActiveChip(catId) {
      if (catId === activeCat) return;
      activeCat = catId;
      const bar = $("#catbar");
      $$(".chip").forEach((c) => {
        const on = c.dataset.cat === catId;
        c.classList.toggle("on", on);
        if (on && bar) {
          // κεντράρισε το ενεργό chip μέσα στη μπάρα (χωρίς scrollIntoView)
          const target = c.offsetLeft - (bar.clientWidth - c.clientWidth) / 2;
          bar.scrollTo({ left: Math.max(0, target), behavior: "smooth" });
        }
      });
    }

    function onScroll() {
      if (suppressSpy) return;
      const offset = headOffset() + 14;
      const secs = $$(".menu-section");
      let current = secs.length ? secs[0].dataset.cat : null;
      for (const s of secs) {
        if (s.getBoundingClientRect().top - offset <= 0) current = s.dataset.cat;
        else break;
      }
      // αν είμαστε στο τέλος της σελίδας, ενεργοποίησε την τελευταία κατηγορία
      if (window.innerHeight + window.scrollY >= document.body.scrollHeight - 4 && secs.length) {
        current = secs[secs.length - 1].dataset.cat;
      }
      if (current) setActiveChip(current);
    }

    function scrollToCat(catId) {
      const sec = document.getElementById("sec-" + catId);
      if (!sec) return;
      setActiveChip(catId);
      suppressSpy = true;
      const top = sec.getBoundingClientRect().top + window.scrollY - headOffset() + 2;
      window.scrollTo({ top: Math.max(0, top), behavior: "smooth" });
      clearTimeout(scrollToCat._t);
      scrollToCat._t = setTimeout(() => { suppressSpy = false; onScroll(); }, 650);
    }

    function showView(id) {
      $$(".view").forEach((v) => v.classList.remove("active"));
      const el = document.getElementById("view-" + id);
      if (el) el.classList.add("active");
    }

    function route() {
      const hash = location.hash.replace(/^#/, "");
      if (hash === "menu") {
        showView("menu");
        renderMenu();
        requestAnimationFrame(() => { onScroll(); });
      } else {
        showView("splash");
      }
    }

    function applyLang() {
      document.documentElement.lang = lang === "gr" ? "el" : "en";
      $("#btn-enter").textContent = I18N[lang].enter;
      $$(".footer-powered").forEach((f) => (f.textContent = I18N[lang].poweredBy));
      $$(".lang-toggle button").forEach((b) => b.classList.toggle("on", b.dataset.lang === lang));
    }

    function setLang(l) {
      if (l === lang) return;
      const keep = activeCat;          // διατήρησε την τρέχουσα κατηγορία
      lang = l; store.set("filips-lang", l);
      applyLang();
      if (document.getElementById("view-menu").classList.contains("active")) {
        renderMenu();
        activeCat = null;
        if (keep) {
          // πήγαινε στην ίδια κατηγορία (άμεσα, χωρίς animation)
          const sec = document.getElementById("sec-" + keep);
          if (sec) {
            const top = sec.getBoundingClientRect().top + window.scrollY - headOffset() + 2;
            window.scrollTo({ top: Math.max(0, top) });
          }
          setActiveChip(keep);
        } else {
          onScroll();
        }
      }
    }

    function bind() {
      $("#btn-enter").addEventListener("click", () => { location.hash = "menu"; });
      $("#catbar").addEventListener("click", (e) => {
        const chip = e.target.closest(".chip");
        if (chip) scrollToCat(chip.dataset.cat);
      });
      $$(".lang-toggle button").forEach((b) => b.addEventListener("click", () => setLang(b.dataset.lang)));
      window.addEventListener("hashchange", route);
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", () => {
        document.documentElement.style.setProperty("--head-h", headOffset() + "px");
      });
    }

    function init() {
      if (MENU.brand) {
        const slg = MENU.brand.slogans || [];
        const pick = slg[Math.floor(Math.random() * slg.length)] || "Every Drink Shines";
        $$(".footer-slogan").forEach((e) => (e.textContent = pick));
      }
      bind();
      applyLang();
      route();
      requestAnimationFrame(() => document.documentElement.style.setProperty("--head-h", headOffset() + "px"));
    }

    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
    else init();
  })();
  </script>
